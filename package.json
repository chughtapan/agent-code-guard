{
  "name": "eslint-plugin-agent-code-guard",
  "version": "0.0.13",
  "description": "ESLint plugin that guards AI-agent-written TypeScript against common sloppy patterns: async/Promise/.then chains, bare catches, unsafe casts, raw SQL, manual enum casts, mocks in integration tests, and hardcoded secrets.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agent-code-guard-knip": "./dist/knip.js",
    "agent-code-guard-init": "./dist/init.js",
    "agent-code-guard-lsp": "./dist/server/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm clean && tsc",
    "lint": "eslint . && knip",
    "test": "vitest run --changed",
    "test:all": "vitest run",
    "bench": "tsx bench/lint-bench.ts",
    "bench:generate": "tsx bench/generate-fixture.ts",
    "mutation": "stryker run",
    "prepublishOnly": "pnpm build && pnpm test:all"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "typescript",
    "effect",
    "kysely",
    "safer-by-default"
  ],
  "license": "MIT",
  "author": "Tapan Chugh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chughtapan/agent-code-guard.git"
  },
  "homepage": "https://github.com/chughtapan/agent-code-guard#readme",
  "bugs": {
    "url": "https://github.com/chughtapan/agent-code-guard/issues"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.0.0",
    "effect": "^3.21.1",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "knip": "^6.12.1",
    "vscode-languageserver": "^9.0.1"
  },
  "peerDependencies": {
    "eslint": ">=9",
    "typescript": ">=5"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^22.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/rule-tester": "^8.0.0",
    "chokidar": "^5.0.0",
    "eslint": "^9.0.0",
    "fast-check": "^4.7.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
